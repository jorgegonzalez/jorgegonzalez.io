---
import Base from '../layouts/Base.astro';

const now = [
  {
    label: 'Day job',
    name: 'Rewst',
    role: 'Engineering Lead',
    blurb:
      'Org-wide technical lead — setting engineering direction while staying deep in production reliability, database performance, and feature delivery.',
    href: 'https://www.rewst.io',
    cta: 'rewst.io',
  },
  {
    label: 'Studio',
    name: 'Ginyu',
    role: 'Designer & engineer',
    blurb:
      'A boutique software and design studio building thoughtful digital products for niche communities.',
    href: 'https://www.ginyu.io',
    cta: 'ginyu.io',
  },
  {
    label: 'Live product',
    name: 'Probed',
    role: 'Founder & builder',
    blurb:
      'Direct-to-customer communication for solo founders and creators. One space, real conversations, no tickets.',
    href: 'https://probed.chat',
    cta: 'probed.chat',
  },
];

const experience = [
  {
    company: 'Rewst',
    role: 'Engineering Lead',
    progression: 'Senior → Principal → Lead',
    period: '2022 — Present',
    stack: ['React', 'TypeScript', 'Node.js', 'Python', 'Go', 'Postgres', 'Redis', 'Kafka', 'RabbitMQ', 'Terraform', 'EKS'],
  },
  {
    company: 'Walmart Global Tech',
    role: 'Software Engineer 3',
    period: '2022',
    stack: ['F#', '.NET'],
  },
  {
    company: 'Raft',
    role: 'Full Stack Engineer',
    period: '2021 — 2022',
    stack: ['React', 'Django', 'Node.js', 'Postgres', 'Terraform'],
  },
  {
    company: 'Perch Security',
    role: 'Software Engineer',
    progression: 'Acquired by ConnectWise',
    period: '2020 — 2021',
    stack: ['Node.js', 'Kafka', 'Django', 'React', 'Elasticsearch', 'Kibana'],
  },
  {
    company: 'JPMorgan Chase',
    role: 'Software Engineer I, II',
    period: '2018 — 2020',
    stack: ['Java', 'React', 'Redux', 'Apollo GraphQL', 'Express', 'Node.js', 'Kafka'],
  },
  {
    company: 'JPMorgan Chase',
    role: 'Software Engineering Intern',
    period: 'Summer 2017',
    stack: ['Java', 'Spring Boot', 'React'],
  },
];

const projects = [
  {
    name: 'Probed',
    blurb:
      'Discord-inspired direct-to-customer chat platform for solo founders, creators, and support teams.',
    href: 'https://probed.chat',
    cta: 'probed.chat',
    stack: ['Electron', 'React', 'Hono / Bun', 'Drizzle', 'Supabase', 'Stripe'],
  },
  {
    name: 'Roshi',
    blurb:
      'A Hebrew calendar iOS app with widgets, Live Activities, and subscriptions — built solo and live on the App Store, generating recurring revenue from an active subscriber base.',
    href: 'https://www.ginyu.io/roshi',
    cta: 'ginyu.io/roshi',
    stack: ['SwiftUI', 'RevenueCat', 'StoreKit 2'],
  },
  {
    name: 'Invader',
    blurb:
      'A fast, native iOS 26 podcast player that trims silence, sharpens every voice, and never phones home about you — privacy-first audio, processed entirely on-device.',
    href: 'https://invader.gg',
    cta: 'invader.gg',
    stack: ['SwiftUI', 'AVFoundation', 'SwiftData'],
  },
  {
    name: 'Rewst TCG Server',
    blurb:
      'A Slack-driven Rails trading card game — packs, trading, marketplace, duels, and leaderboards — with a fully audited transactional economy.',
    href: null,
    cta: null,
    stack: ['Ruby on Rails', 'Supabase', 'Fly.io', 'SolidQueue'],
  },
];

const skills = [
  {
    title: 'Languages & Frameworks',
    items: ['TypeScript', 'Python', 'JavaScript', 'Ruby / Rails', 'Swift / SwiftUI', 'Kotlin', 'Java', 'F#', 'Go', 'React', 'Electron', 'Node.js', 'Bun', 'Django'],
  },
  {
    title: 'Infrastructure & Data',
    items: ['AWS', 'Kubernetes', 'Docker', 'Terraform', 'GitHub Actions', 'GitOps', 'Vercel', 'Cloudflare', 'PostgreSQL', 'Redis', 'Kafka', 'RabbitMQ', 'Elasticsearch', 'Logstash', 'Kibana', 'Prometheus', 'GraphQL', 'REST', 'Supabase', 'Stripe', 'Caddy', 'LaunchDarkly', 'Statsig'],
  },
];
---

<Base title="Jorge R. Gonzalez — Engineering Leader">
  <section class="hero">
    <p class="eyebrow"><span class="dot"></span>Engineering Leader · New York City</p>
    <h1>I turn hard problems into shipped software.</h1>
    <p class="subtitle">
      Generalist engineering leader with 8+ years building in regulated, high-stakes industries —
      finance, government, security, and IT. I do my best work with startups and early-stage
      teams — partnering directly with customers, multiplying my team with agentic coding
      tools like Claude Code, and shipping side projects on nights and weekends.
    </p>
    <div class="hero-actions">
      <a class="btn primary" href="#work">See what I'm building</a>
      <a class="btn" href="https://github.com/jorgegonzalez" target="_blank" rel="noopener">GitHub<span class="arr">↗</span></a>
      <a class="btn" href="https://www.linkedin.com/in/7cf303464fb4/" target="_blank" rel="noopener">LinkedIn<span class="arr">↗</span></a>
    </div>
  </section>

  <section id="work" class="block block--wide">
    <h2 class="section-label">Now</h2>
    <div class="now-list">
      {
        now.map((item) => (
          <a class="now-card" href={item.href} target="_blank" rel="noopener">
            <div class="now-head">
              <span class="badge">{item.label}</span>
              <span class="now-cta">{item.cta}<span class="arr">↗</span></span>
            </div>
            <h3>{item.name}</h3>
            <p class="now-role">{item.role}</p>
            <p class="now-blurb">{item.blurb}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section id="experience" class="block">
    <h2 class="section-label">Experience</h2>
    <div class="timeline">
      {
        experience.map((job) => (
          <div class="job">
            <div class="job-meta">
              <span class="job-period">{job.period}</span>
            </div>
            <div class="job-body">
              <div class="job-head">
                <h3>{job.company}</h3>
                <span class="job-role">{job.role}</span>
                {job.progression && <span class="job-progression">{job.progression}</span>}
              </div>
              <div class="tags">
                {job.stack.map((s) => (
                  <span class="tag">{s}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <p class="edu">Bachelor of Science in Computer Science · 2018</p>
  </section>

  <section id="projects" class="block">
    <h2 class="section-label">Selected projects</h2>
    <div class="project-list">
      {
        projects.map((p) => {
          const Tag = p.href ? 'a' : 'div';
          return (
            <Tag
              class:list={['project-card', { static: !p.href }]}
              href={p.href}
              target={p.href ? '_blank' : undefined}
              rel={p.href ? 'noopener' : undefined}
            >
              <div class="project-head">
                <h3>{p.name}</h3>
                {p.cta && <span class="now-cta">{p.cta}<span class="arr">↗</span></span>}
              </div>
              <p class="project-blurb">{p.blurb}</p>
              <div class="tags">
                {p.stack.map((s) => (
                  <span class="tag">{s}</span>
                ))}
              </div>
            </Tag>
          );
        })
      }
    </div>
  </section>

  <section class="block">
    <h2 class="section-label">Toolbox</h2>
    <div class="skills">
      {
        skills.map((group) => (
          <div class="skill-group">
            <h3>{group.title}</h3>
            <div class="tags">
              {group.items.map((s) => (
                <span class="tag">{s}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section id="contact" class="block contact">
    <h2>Let's build something.</h2>
    <p>
      I'm always up for a conversation about hard engineering problems, high-stakes
      systems, or where agentic AI is actually going.
    </p>
    <div class="hero-actions">
      <a class="btn primary" href="mailto:jorge@ginyu.io">jorge@ginyu.io</a>
      <a class="btn" href="https://github.com/jorgegonzalez" target="_blank" rel="noopener">GitHub<span class="arr">↗</span></a>
      <a class="btn" href="https://www.linkedin.com/in/7cf303464fb4/" target="_blank" rel="noopener">LinkedIn<span class="arr">↗</span></a>
      <a class="btn" href="https://buymeacoffee.com/jorgegonzalez" target="_blank" rel="noopener">☕ Buy me a coffee<span class="arr">↗</span></a>
    </div>
  </section>
</Base>

<style>
  .hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 7rem 2rem 4rem;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 1.75rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 2rem;
    background: var(--surface);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.15);
  }

  h1 {
    font-size: clamp(2.1rem, 6vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: linear-gradient(to bottom, #ffffff, rgba(255, 255, 255, 0.72));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .subtitle {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 580px;
    margin: 0 auto;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.25rem;
  }

  .btn {
    font-size: 0.9rem;
    padding: 0.65rem 1.15rem;
    border-radius: 0.6rem;
    border: 1px solid var(--line-strong);
    color: rgba(255, 255, 255, 0.85);
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .btn:hover {
    border-color: rgba(255, 255, 255, 0.35);
    background: var(--surface-hover);
    color: #fff;
  }

  .btn.primary {
    background: #fff;
    color: #000;
    border-color: #fff;
    font-weight: 500;
  }

  .btn.primary:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  /* shared section scaffolding */
  .block {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .block--wide {
    max-width: 1000px;
  }

  /* small trailing "open in new tab" arrow */
  .arr {
    display: inline-block;
    font-size: 0.7em;
    margin-left: 0.3em;
    transform: translateY(-0.05em);
    opacity: 0.7;
  }

  .btn .arr {
    opacity: 0.55;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    margin-bottom: 1.75rem;
  }

  h3 {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  /* now / current work */
  .now-list {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .now-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: var(--surface);
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }

  .now-card:hover {
    border-color: var(--line-strong);
    background: var(--surface-hover);
    transform: translateY(-2px);
  }

  .now-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.08);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    font-size: 0.68rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .now-cta {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    transition: color 0.2s;
    white-space: nowrap;
  }

  .now-card:hover .now-cta,
  .project-card:hover .now-cta {
    color: var(--accent);
  }

  .now-role {
    font-size: 0.8rem;
    color: var(--text-faint);
    margin: 0.25rem 0 0.75rem;
  }

  .now-blurb {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* experience timeline */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .job {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--line);
  }

  .job:first-child {
    border-top: none;
    padding-top: 0;
  }

  .job-period {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    white-space: nowrap;
  }

  .job-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    margin-bottom: 0.6rem;
  }

  .job-role {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .job-progression {
    font-size: 0.72rem;
    color: var(--text-faint);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 0.1rem 0.55rem;
  }

  .edu {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    color: var(--text-faint);
  }

  /* tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--line);
    border-radius: 0.4rem;
    background: rgba(255, 255, 255, 0.02);
  }

  /* projects */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card {
    display: block;
    padding: 1.5rem;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: var(--surface);
    transition: border-color 0.2s, background 0.2s;
  }

  .project-card:not(.static):hover {
    border-color: var(--line-strong);
    background: var(--surface-hover);
  }

  .project-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .project-blurb {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: 0.85rem;
  }

  /* skills */
  .skills {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-group h3 {
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin-bottom: 0.85rem;
  }

  /* contact */
  .contact {
    text-align: center;
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .contact h2 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }

  .contact p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto;
  }

  .contact .hero-actions {
    margin-top: 2rem;
  }

  @media (max-width: 760px) {
    .now-list {
      grid-template-columns: 1fr;
    }

    .skills {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4.5rem 1.25rem 3rem;
    }

    .block {
      padding: 2.5rem 1.25rem;
    }

    .job {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
